# =====================================================================
# MEME Atelier — Environment Variables
# =====================================================================
# Copy this file to .env.local (Next.js local dev) and fill in the values.
# For Vercel, add the same keys in Project Settings → Environment Variables.
# =====================================================================

# ---- Supabase (REQUIRED for production) ----
# 1. Go to https://supabase.com and create a new project
# 2. Project Settings → API → copy URL and anon key
# 3. Project Settings → API → copy service_role key (KEEP SECRET — server only)
# 4. Run supabase/schema.sql in the SQL Editor
# 5. Create a Storage bucket named "product-images" (public read)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- Stripe (REQUIRED for real payments) ----
# Get these from https://dashboard.stripe.com/apikeys
# Webhook signing secret: Stripe Dashboard → Developers → Webhooks → your endpoint
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ---- Site URL (used for canonical URLs & OG metadata) ----
# For local dev: http://localhost:3000
# For Vercel: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Email (Resend — optional, for order confirmations) ----
RESEND_API_KEY=re_xxx
EMAIL_FROM="MEME Atelier <atelier@memefashion.com>"

# ---- Analytics (optional) ----
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=

# ---- Logging (optional) ----
# One of: debug | info | warn | error
LOG_LEVEL=info
